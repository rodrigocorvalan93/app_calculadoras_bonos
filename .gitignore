build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
pip-wheel-metadata/
MANIFEST

# Virtual envs (cualquier convención)
.venv/
venv/
env/
.env_venv/
ENV/
env.bak/
venv.bak/

# Pyenv / pipenv / poetry lock local
.python-version
Pipfile.lock
poetry.lock
# Nota: si querés versionar poetry.lock (recomendado), quitá la línea de arriba.

# Tests / coverage / type-checking
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/
