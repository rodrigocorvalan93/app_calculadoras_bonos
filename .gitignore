.pytype/
.ruff_cache/


# ──────────────────────────────────────────────────────────────
# 🎛️ Streamlit
# ──────────────────────────────────────────────────────────────
# El config.toml local puede tener puertos / creds → no subir
.streamlit/secrets.toml
# Pero sí versioná el config base si lo tenés:
# (dejalo visible, no está ignorado)


# ──────────────────────────────────────────────────────────────
# 📓 Jupyter / notebooks
# ──────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints
*-checkpoint.ipynb
profile_default/
ipython_config.py


# ──────────────────────────────────────────────────────────────
# 💻 VS Code
# ──────────────────────────────────────────────────────────────
# .vscode/ suele tener settings personales (paths locales, etc.)
# Si querés compartir una config de equipo, versioná sólo settings.json
# y launch.json explícitamente con `git add -f`.
.vscode/
*.code-workspace


# ──────────────────────────────────────────────────────────────
# 🪟 Windows
# ──────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk


# ──────────────────────────────────────────────────────────────
# ☁️ OneDrive (archivos de conflicto y marcadores de sync)
# ──────────────────────────────────────────────────────────────
# Cuando OneDrive detecta conflictos de edición genera archivos con sufijo.
# Los nombres varían según idioma del sistema (ES/EN) y tipo de conflicto.
*- Copia.*
*- Copia (*).*
*- Copy.*
*- Copy (*).*
*- Conflicto*
*- Conflict*
*(conflicted copy*).*
*.sb-*


# ──────────────────────────────────────────────────────────────
# 🍏 macOS (por si alguien del equipo usa Mac)
# ──────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes


# ──────────────────────────────────────────────────────────────
# 📝 Logs / output
# ──────────────────────────────────────────────────────────────
*.log
logs/
*.log.*
debug.log
npm-debug.log*


# ──────────────────────────────────────────────────────────────
# 📦 Archivos temporales / editor
# ──────────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.swp
*.swo
*~
.idea/


# ======================================================================
# 💡 CÓMO AGREGAR UNA EXCEPCIÓN
# ======================================================================
# Si algún día querés versionar un archivo que un patrón está ignorando,
# agregalo con '!' al final del .gitignore. Ejemplo:
#
#     !ejemplo_composicion.xlsx      ← este sí se versiona
#
# Y forzá el add con:
#     git add -f ejemplo_composicion.xlsx
# ======================================================================
