# ======================================================================
# .gitignore — app_calculadoras_bonos
# ======================================================================
# Stack: Python 3.x + Streamlit + VS Code + Windows + OneDrive
# Objetivo: nunca versionar secretos, datos internos, cachés ni basura de
# OS/IDE. Sólo el código fuente y la documentación.
# ======================================================================


# ──────────────────────────────────────────────────────────────
# 🗂️ Archivos y carpetas locales del proyecto (NO versionar)
# ──────────────────────────────────────────────────────────────
# Versiones personales / scripts locales que no son parte del core.
OMSweb_appJIP.py
OMSweb_app*JIP*.py
generar_reporte.py
generar_fondos.py

# Data interna (scoring crediticio propietario, etc.)
credit_scores.json
credit_scores_*.json

# Carpetas de versiones anteriores y experimentos
curvas/
old/
old OMS module/
old_OMS_module/
archive/
backup/


# ──────────────────────────────────────────────────────────────
# 🔐 SECRETOS Y CREDENCIALES  —  NUNCA SUBIR
# ──────────────────────────────────────────────────────────────
secrets.txt
secrets.*.txt
*.secrets
.env
.env.*
!.env.example
credentials.json
credentials.*.json
*.key
*.pem
*.pfx
auth_token*
oms_session*


# ──────────────────────────────────────────────────────────────
# 📊 DATOS INTERNOS DE DELTA  —  NO versionar planillas de negocio
# ──────────────────────────────────────────────────────────────
# Las bases de Delta viven en OneDrive, no en el repo.
Delta_Composicion.xlsx
Delta_PN.xlsx
Delta_Futuros.xlsx
Delta_*.xlsx
Delta_*.xlsm
Delta_*.xlsb
Delta_*.csv
Delta\ -\ *.xlsx
historico_byma_px_tasas.xlsx
historico_byma_*.xlsx
Proyecciones_para_Claude.xlsx
RF_Detalle_Carteras.xlsx
RF_Detalle_Carteras.xlsm
Primary-API.pdf

# Datos descargados / generados localmente
/data/
/datos/
/exports/
*.parquet
*.feather

# Backups temporales de Excel (cuando el archivo está abierto)
~$*.xlsx
~$*.xlsm
~$*.docx


# ──────────────────────────────────────────────────────────────
# 🐍 Python
# ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

